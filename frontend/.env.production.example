# Frontend Production Environment Template
# Copy to .env.production for local production-profile checks.
# For AWS/ECS, set equivalent task/container environment variables and use
# FRONTEND_BUILD_ENV_FILE when building if NEXT_PUBLIC_* values must be baked.

# Public browser-facing backend URL.
# Local unified prod uses HTTP. Replace with HTTPS domains for AWS/production.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Server-side backend URL for Next.js API routes.
# Local Compose can use http://app:8000. AWS should use the internal service
# discovery name, ALB URL, or private backend endpoint appropriate to the task.
BACKEND_API_URL=http://app:8000
BACKEND_API_PREFIX=/api/v1

NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production

NEXT_PUBLIC_ENABLE_SECURITY_HEADERS=true
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000

NEXT_PUBLIC_COOKIE_AUTH_ENABLED=true
NEXT_PUBLIC_ACCESS_TOKEN_NAME=koiki_access_token
NEXT_PUBLIC_REFRESH_TOKEN_NAME=koiki_refresh_token
NEXT_PUBLIC_COOKIE_SAMESITE=lax
NEXT_PUBLIC_COOKIE_SECURE=false

NEXT_PUBLIC_DEFAULT_THEME=system
NEXT_PUBLIC_ENABLE_DEV_TOOLS=false
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_API_TIMEOUT=30000

NEXT_PUBLIC_APP_NAME=KOIKI Framework Frontend
NEXT_PUBLIC_APP_VERSION=0.1.0
