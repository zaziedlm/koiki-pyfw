# =============================
# KOIKI v0.7 Production Environment Template
# =============================
# Copy to .env.production for local Docker Compose production-profile checks.
# For AWS/ECS, prefer task definition secrets/environment variables instead of
# committing or baking this file into an image.

COMPOSE_PROJECT_NAME=koiki_v07
ENV_FILE=.env.production
RESTART_POLICY=unless-stopped

# Ports exposed by local Docker Compose only.
APP_PORT=8000
FRONTEND_PORT=3000
DB_PORT=5432
KEYCLOAK_HTTP_PORT=8090
KEYCLOAK_MGMT_PORT=9000

# Application
APP_ENV=production
ENVIRONMENT=production
DEBUG=False
SERVER_HOST=https://api.example.com
BACKEND_CORS_ORIGINS=["https://app.example.com"]
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TIMEZONE=Asia/Tokyo

# Database
# Local Docker Compose prod profile can use db:5432.
# AWS should normally use the RDS endpoint and inject the password via secrets.
DATABASE_URL=postgresql+asyncpg://koiki_user:CHANGE_ME_DB_PASSWORD@db:5432/koiki_todo_db
POSTGRES_SERVER=db
POSTGRES_USER=koiki_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=koiki_todo_db
POSTGRES_PORT=5432
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# JWT
# Use at least 32 random bytes for HS256. Do not reuse this placeholder.
JWT_SECRET=CHANGE_ME_USE_32_BYTES_OR_MORE_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis / rate limiting
REDIS_ENABLED=false
# REDIS_URL=redis://redis:6379/0

# SSO / OIDC
SSO_CLIENT_ID=koiki-backend
SSO_CLIENT_SECRET=CHANGE_ME_SSO_CLIENT_SECRET
SSO_ISSUER_URL=https://idp.example.com/realms/koiki
SSO_AUTHORIZATION_ENDPOINT=https://idp.example.com/realms/koiki/protocol/openid-connect/auth
SSO_TOKEN_ENDPOINT=https://idp.example.com/realms/koiki/protocol/openid-connect/token
SSO_JWKS_URI=https://idp.example.com/realms/koiki/protocol/openid-connect/certs
SSO_DEFAULT_PROVIDER=oidc
SSO_DEFAULT_SCOPES=openid email profile
SSO_DEFAULT_REDIRECT_URI=https://app.example.com/sso/callback
SSO_ALLOWED_REDIRECT_URIS=https://app.example.com/*
SSO_ALLOWED_DOMAINS=
SSO_REQUIRE_EMAIL_VERIFIED=true
SSO_AUTO_CREATE_USERS=true
SSO_LINK_BACKEND=user_sso
SSO_TOKEN_CACHE_TTL=300
SSO_STATE_SIGNING_KEY=CHANGE_ME_USE_32_BYTES_OR_MORE_RANDOM_STATE_SECRET
SSO_STATE_TTL_SECONDS=600
SSO_AUDIENCE_VALIDATION=true
SSO_ISSUER_VALIDATION=true
SSO_SIGNATURE_VALIDATION=true
SSO_EXPIRY_VALIDATION=true
SSO_CLOCK_SKEW_SECONDS=30
SSO_ALLOWED_ALGORITHMS=RS256
SSO_EXPECTED_AZP=
SSO_USER_INFO_ENDPOINT=
SSO_DEBUG_MODE=false
SSO_SKIP_SSL_VERIFY=false

# Keycloak local production-profile defaults.
# For AWS/external IdP, app-prod-external does not start local Keycloak.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
