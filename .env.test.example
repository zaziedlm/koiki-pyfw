# Test Environment Template
# Copy to a local ignored env file if a test workflow needs file-based settings.
# The current pytest fixtures set most test values directly; CI uses .env.ci.

APP_ENV=testing
DEBUG=true

# Database settings for local test runs that need PostgreSQL.
DATABASE_URL=postgresql+asyncpg://koiki_user:koiki_password@localhost:5432/koiki_todo_db

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

REDIS_ENABLED=false

SECRET_KEY=test-secret-key
JWT_SECRET=test-jwt-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

LOG_LEVEL=INFO
LOG_FORMAT=json

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
